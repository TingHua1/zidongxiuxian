# TG Text Game Assistant example environment
# 复制本文件为 .env 后，再填入你自己的真实值。

# --- Web / app ---
TG_GAME_DEBUG=0
TG_GAME_HOST=127.0.0.1
TG_GAME_PORT=8000

# --- Telegram 登录 ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TG_GAME_SESSION_NAME=tg_game
TG_GAME_LOGIN_SESSION_NAME=tg_game_login

# --- 绑定目标群 / 话题 / Bot ---
TG_GAME_BOUND_CHAT_ID=
TG_GAME_BOUND_THREAD_ID=
TG_GAME_BOUND_CHAT_TYPE=group
TG_GAME_BOUND_BOT_USERNAME=fanrenxiuxian_bot
TG_GAME_BOUND_BOT_ID=

# --- 外部账号 / 保活 ---
TG_GAME_EXTERNAL_KEEPALIVE_SECONDS=900
TG_GAME_EXTERNAL_KEEPALIVE_POLL_SECONDS=30
TG_GAME_LOG_MESSAGES=0

# --- 管理员 ---
AUTHORIZED_USER_ID=

# --- 凡人修仙自动闭关 ---
FANREN_BOT_USERNAME=fanrenxiuxian_bot
FANREN_CHECK_COMMAND=.查看闭关
FANREN_NORMAL_COMMAND=.闭关修炼
FANREN_DEEP_COMMAND=.深度闭关
FANREN_DEFAULT_MODE=normal
FANREN_DEFAULT_INTERVAL=300
FANREN_COMMAND_COOLDOWN=30
FANREN_MAX_FAILURES=3
FANREN_MIN_INTERVAL=30
FANREN_RUNNER_POLL_SECONDS=5
FANREN_REPLY_SYNC_GRACE_SECONDS=300

# --- 宗门自动任务 ---
SECT_BOT_USERNAME=fanrenxiuxian_bot
SECT_CHECK_COMMAND=.我的宗门
SECT_DEFAULT_INTERVAL=1800
SECT_COMMAND_COOLDOWN=15
SECT_RUNNER_POLL_SECONDS=5
SECT_DAILY_TEACH_LIMIT=3
SECT_AUTO_CHECK_IN_TIME=02:00
SECT_AUTO_TEACH_TIME=02:10
YINLUO_AUTO_SACRIFICE_TIME=02:20
